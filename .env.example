# AI プロバイダ (openai または gemini)
# OPENAI_API_KEY が設定されている場合、未設定でも openai が選ばれます。
AI_PROVIDER="openai"

# OpenAI APIキー (openai 利用時に必須)
OPENAI_API_KEY="YOUR_OPENAI_API_KEY_HERE"

# OpenAI モデル (任意)
# 例: OPENAI_MODEL="gpt-4o-mini"
OPENAI_MODEL="gpt-4o-mini"

# Gemini APIキー (gemini 利用時に必須)
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# Gemini モデル (任意、デフォルトは gemini-1.5-flash)
# 例: GEMINI_MODEL="gemini-1.5-flash"
GEMINI_MODEL="gemini-1.5-flash"

# 翻訳プロンプト (任意、未設定または空の場合はスクリプト内のデフォルトプロンプトを使用)
# Docker Compose 互換のため 1 行で指定してください。
# 例:
# TRANSLATION_PROMPT="Translate to ${language}. Return items separated by ${uniqueSeparator}. Texts: ${textsToTranslate}"

# 翻訳対象言語 (任意、未設定の場合は日本語のみを対象とします)
# JSON形式の文字列で、オブジェクトの配列として指定します。
# 各オブジェクトは "name" (言語コード、例: "en", "ko") と "label" (言語名、例: "English", "韓国語") を持つ必要があります。
# 例: TARGET_LANGUAGES='[{"name":"ja","label":"日本語"},{"name":"en","label":"English"}]'
TARGET_LANGUAGES='[{"name":"ja","label":"日本語"}]'